<Window x:Class="QRCodeToolbox.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QRCodeToolbox"
        mc:Ignorable="d"
        Title="QR Code Toolbox" Height="600" Width="900" MinHeight="400" MinWidth="600">
    <Grid Background="{DynamicResource WindowBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                   Text="QR Code Generator"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimary}"
                   Margin="20,15,20,10"/>

        <!-- Input Section -->
        <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="20,0,20,15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Text Input Label -->
            <TextBlock Grid.Row="0" Grid.Column="0"
                       Text="Text to Encode:"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimary}"
                       Margin="0,0,0,5"/>

            <!-- Size Label -->
            <TextBlock Grid.Row="0" Grid.Column="1"
                       Text="Module Size:"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimary}"
                       Margin="10,0,0,5"/>

            <!-- Text Input -->
            <TextBox Grid.Row="1" Grid.Column="0"
                     Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                     Background="{DynamicResource InputBackground}"
                     Foreground="{DynamicResource TextPrimary}"
                     CaretBrush="{DynamicResource TextPrimary}"
                     Padding="10"
                     Margin="0,0,10,0"
                     TextWrapping="Wrap"
                     MinHeight="60"
                     VerticalAlignment="Top"/>

            <!-- Size Selector -->
            <Grid Grid.Row="1" Grid.Column="1" Margin="10,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Slider Grid.Column="0"
                        Minimum="30"
                        Maximum="70"
                        Value="{Binding PixelsPerModule}"
                        VerticalAlignment="Center"
                        Margin="0,0,5,0"/>

                <TextBlock Grid.Column="1"
                           Text="{Binding PixelsPerModule}"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimary}"
                           VerticalAlignment="Center"
                           Width="25"/>
            </Grid>

            <!-- Action Buttons -->
            <StackPanel Grid.Row="1" Grid.Column="2"
                        Orientation="Vertical"
                        Margin="10,0,0,0"
                        VerticalAlignment="Top">
                <Button Content="Generate"
                        Command="{Binding GenerateCommand}"
                        Background="#0078D4"
                        Foreground="Black"
                        FontWeight="Bold"
                        Padding="15,10"
                        Cursor="Hand"
                        Margin="0,0,0,5"/>
                <Button Content="Clear"
                        Command="{Binding ClearCommand}"
                        Background="#666"
                        Foreground="Black"
                        FontWeight="Bold"
                        Padding="15,10"
                        Cursor="Hand"/>
            </StackPanel>
        </Grid>

        <!-- QR Code Display Section -->
        <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                Background="{DynamicResource CardBackground}"
                Margin="20,0,20,15"
                BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="QR Code Preview:"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimary}"
                           Margin="15,15,15,10"/>

                <Image Grid.Row="1"
                       Source="{Binding QRCodeImage}"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       MaxWidth="500"
                       MaxHeight="500"
                       Margin="15,10,15,15"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
            </Grid>
        </Border>


        <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="20,0,20,15">
            <Button Content="Save as PNG"
                    Command="{Binding SaveCommand}"
                    Background="#28A745"
                    Foreground="Black"
                    FontWeight="Bold"
                    Padding="20,10"
                    Margin="0,0,10,0"
                    Cursor="Hand"
                    MinWidth="120"/>
            <Button Content="Copy to Clipboard"
                    Command="{Binding CopyCommand}"
                    Background="#17A2B8"
                    Foreground="Black"
                    FontWeight="Bold"
                    Padding="20,10"
                    Cursor="Hand"
                    MinWidth="140"/>
        </StackPanel>

        <!-- Status Message -->
        <Border Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2"
                Background="{DynamicResource StatusBackground}"
                Padding="15"
                Margin="0"
                BorderBrush="{DynamicResource StatusBorderColor}"
                BorderThickness="0,1,0,0">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{DynamicResource TextPrimary}"
                       FontSize="12"/>
        </Border>
    </Grid>
</Window>
